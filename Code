    <style>
        /* Reset default styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background-color: #f0f4f7;
            color: #333;
            line-height: 1.6;
        }

        /* Header Styling */
        header {
            background: #2c3e50;
            color: white;
            padding: 15px 0;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        header .navbar {
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        header .navbar a {
            color: white;
            text-decoration: none;
            padding: 8px 15px;
            font-size: 18px;
            transition: background 0.3s ease;
        }

        header .navbar a:hover {
            background: #34495e;
            border-radius: 5px;
        }

        /* Home Section Styling */
        .home {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 50px 5%;
            background: #ecf0f1;
        }

        .home-img img {
            border-radius: 50%;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .home-content {
            max-width: 600px;
        }

        .home-content h3 {
            font-size: 24px;
            font-weight: normal;
            margin-bottom: 10px;
            color: #7f8c8d;
        }

        .home-content h1 {
            font-size: 40px;
            font-weight: bold;
            margin-bottom: 10px;
            color: #2c3e50;
        }

        .home-content h3 span {
            font-weight: bold;
            color: #16a085;
        }

        .social-media {
            margin-top: 20px;
        }

        .social-media a {
            color: #16a085;
            font-size: 24px;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .social-media a:hover {
            color: #2c3e50;
        }

        /* Add responsive styling for mobile view */
        @media (max-width: 768px) {
            .home {
                flex-direction: column;
                text-align: center;
            }

            .home-img img {
                width: 200px;
                height: 200px;
            }

            .home-content {
                max-width: 100%;
                margin-top: 20px;
            }

            .navbar {
                flex-direction: column;
            }

            .navbar a {
                padding: 10px;
                font-size: 16px;
            }
        }
    </style>
</head>
